-- =========================================================
-- 27. TẠO VIEW TÓM TẮT CHO BÁO CÁO
-- =========================================================

DROP VIEW IF EXISTS report_summary_view;

CREATE VIEW report_summary_view AS
SELECT
    soc_code,
    occupation_title,
    total_employment,
    annual_median_wage,
    annual_mean_wage,
    num_technology_skills,
    num_technology_categories,
    num_hot_technology,
    num_in_demand_technology,
    has_python,
    has_sql,
    has_excel,
    has_tableau,
    has_r
FROM final_dataset;

SELECT *
FROM report_summary_view
LIMIT 20;


-- =========================================================
-- 28. TẠO VIEW NHÓM NGHỀ CÔNG NGHỆ CAO
-- =========================================================

DROP VIEW IF EXISTS high_tech_occupations_view;

CREATE VIEW high_tech_occupations_view AS
SELECT
    soc_code,
    occupation_title,
    annual_median_wage,
    num_technology_skills,
    num_hot_technology,
    num_in_demand_technology,
    has_python,
    has_sql,
    has_tableau,
    has_r
FROM final_dataset
WHERE 
    has_python = 1
    OR has_sql = 1
    OR has_tableau = 1
    OR has_r = 1
ORDER BY annual_median_wage DESC;

SELECT *
FROM high_tech_occupations_view
LIMIT 20;


